<%- include("partials/header.ejs") %>



<div class="create-post">
    <h1>Create a New Post</h1>
    <form action="/create" method="POST">
        <label for="post-title">Post Title</label>
        <input type="text" id="post-title" name="post-title" placeholder="Enter the title" required>

        <label for="post-content">Post Content</label>
        <textarea id="post-content" name="post-content" rows="10" placeholder="Write your post here..." required></textarea>

        <label for="post-tags">Tags</label>
        <input type="text" id="post-tags" name="post-tags" placeholder="Enter tags separated by commas">

        <div class="actions">
            <button type="submit" class="btn-submit">Submit Post</button>
            <button type="reset" class="btn-reset">Reset</button>
        </div>
    </form>
</div>


<%- include("partials/footer.ejs") %>