<%- include("partials/header.ejs") %>

<div class="content profile-section">
    <h1>Profile</h1>
    <div class="profile-details">
        <form action="/profile" enctype="multipart/form-data" method="post">
            <div class="profile-picture">
                <img src=<% if(locals.imageDetails && locals.imageDetails.filename){%> 
                    <%= "/images/"+imageDetails.filename %>
                <% } else { %>
                    <%= "/images/one.jpg" %> 
                <%}%> alt = "profile-picture">
                <div>
                    <label for="profile-picture">Change Picture</label>
                    <input type="file" id="profile-picture" name="profile-picture">
                </div>
            </div>
            <label for="name">Name</label>
            <input type="text" id="name" placeholder="Your Name" name="name">
            <label for="email">Email</label>
            <input type="text" id="email" placeholder="Your Email" name="email">
            <label for="bio">Bio</label>
            <textarea id="bio" rows="4" placeholder="Write a short bio..." name="bio"></textarea>
            <div class="actions">
                <button class="btn-save" type="submit">Save Changes</button>
                <button class="btn-cancel">Cancel</button>
            </div>
        </form>
    </div>
</div>




<%- include("partials/footer.ejs") %>